@prefix esg: <http://example.org/esg#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# INDUSTRIES
# =============================================================================

esg:commercialbanks a esg:Industry ;
    rdfs:label "Commercial Banks" ;
    esg:reportsUsing esg:SASBCommercialBanks .

esg:semiconductors a esg:Industry ;
    rdfs:label "Semiconductors" ;
    esg:reportsUsing esg:SASBSemiconductors .

# =============================================================================
# REPORTING FRAMEWORKS
# =============================================================================

esg:SASBCommercialBanks a esg:ReportingFramework ;
    rdfs:label "SASB Commercial Banks" ;
    esg:includes esg:BusinessEthics,
        esg:DataSecurity,
        esg:FinancedEmissions,
        esg:FinancialInclusionCapacityBuilding,
        <http://example.org/esg#IncorporationofEnvironmental,Social,andGovernanceFactorsinCreditAnalysis>,
        esg:SystemicRiskManagement ;
    esg:sourceDocument "commercial-banks-standard_en-gb.pdf" .

esg:SASBSemiconductors a esg:ReportingFramework ;
    rdfs:label "SASB Semiconductors" ;
    esg:includes esg:EnergyManagementinManufacturing,
        esg:GreenhouseGasEmissions,
        esg:MaterialSourcing,
        esg:ProductLifecycleManagement,
        esg:RecruitingManagingaGlobalSkilledWorkforce,
        esg:WasteandHazardousMaterialsManagement,
        esg:WaterManagement,
        esg:WorkforceHealthandSafety ;
    esg:sourceDocument "semiconductors-standard_en-gb.pdf" .

# =============================================================================
# CATEGORIES
# =============================================================================

esg:BusinessEthics a esg:Category ;
    rdfs:label "Business Ethics" ;
    esg:consistsOf esg:LegalProceedingsMonetaryLosses,
        esg:WhistleblowerPoliciesDescription .

esg:DataSecurity a esg:Category ;
    rdfs:label "Data Security" ;
    esg:consistsOf esg:AccountHoldersAffected,
        esg:DataSecurityRiskApproach,
        esg:NumberDataBreaches,
        esg:PercentagePersonalDataBreaches .

esg:EnergyManagementinManufacturing a esg:Category ;
    rdfs:label "Energy Management in Manufacturing" ;
    esg:consistsOf esg:TotalEnergyConsumed,
        esg:PercentageGridElectricity,
        esg:PercentageRenewableEnergy .

esg:FinancedEmissions a esg:Category ;
    rdfs:label "Financed Emissions" ;
    esg:consistsOf esg:FinancedEmissionsCoveragePercentage,
        esg:FinancedEmissionsMethodology,
        esg:Scope1FinancedEmissions,
        esg:Scope2FinancedEmissions,
        esg:Scope3FinancedEmissions .

esg:FinancialInclusionCapacityBuilding a esg:Category ;
    rdfs:label "Financial Inclusion & Capacity Building" ;
    esg:consistsOf esg:FinancialLiteracyParticipants,
        esg:NoCostCheckingAccounts,
        esg:SmallBusinessLoanAmount,
        esg:SmallBusinessLoanCount .

esg:GreenhouseGasEmissions a esg:Category ;
    rdfs:label "Greenhouse Gas Emissions" ;
    esg:consistsOf esg:GrossGlobalScope1Emissions,
        esg:PerfluorinatedCompoundsEmissions,
        esg:Scope1EmissionsStrategy,
        esg:GHGEmissionIntensity .

esg:MaterialSourcing a esg:Category ;
    rdfs:label "Material Sourcing" ;
    esg:consistsOf esg:CriticalMaterialsRiskManagement .

esg:ProductLifecycleManagement a esg:Category ;
    rdfs:label "Product Lifecycle Management" ;
    esg:consistsOf esg:DeclarableSubstancesRevenuePercentage,
        esg:DesktopProcessorEnergyEfficiency,
        esg:LaptopProcessorEnergyEfficiency,
        esg:ServerProcessorEnergyEfficiency .

esg:RecruitingManagingaGlobalSkilledWorkforce a esg:Category ;
    rdfs:label "Recruiting & Managing a Global & Skilled Workforce" ;
    esg:consistsOf esg:WorkVisaEmployeePercentage .

esg:SystemicRiskManagement a esg:Category ;
    rdfs:label "Systemic Risk Management" ;
    esg:consistsOf esg:GSIBScoreByCategory,
        esg:GrossExposureByIndustry,
        esg:StressTestIntegrationApproach .

esg:WasteandHazardousMaterialsManagement a esg:Category ;
    rdfs:label "Waste and Hazardous Materials Management" ;
    esg:consistsOf esg:HazardousWasteAmount,
        esg:PercentageHazardousWasteRecycled .

esg:WaterManagement a esg:Category ;
    rdfs:label "Water Management" ;
    esg:consistsOf esg:TotalWaterConsumed,
        esg:TotalWaterWithdrawn,
        esg:PercentageWaterConsumedHighStress,
        esg:PercentageWaterWithdrawnHighStress .

esg:WorkforceHealthandSafety a esg:Category ;
    rdfs:label "Workforce Health and Safety" ;
    esg:consistsOf esg:HealthSafetyLegalLosses,
        esg:WorkforceHealthHazardEfforts .

<http://example.org/esg#IncorporationofEnvironmental,Social,andGovernanceFactorsinCreditAnalysis> a esg:Category ;
    rdfs:label "Incorporation of Environmental, Social, and Governance Factors in Credit Analysis" ;
    esg:consistsOf esg:ESGCreditAnalysisApproach,
        esg:PastDueLoanAmount,
        esg:PastDueLoanCount .

# =============================================================================
# DIRECT MEASUREMENT METRICS (obtainedFrom DatasetVariable)
# =============================================================================

esg:AccountHoldersAffected a esg:Metric ;
    rdfs:label "Account Holders Affected" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Number of account holders affected" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Number" ;
    esg:obtainedFrom esg:POLICYACCOUNTHOLDERSAFFECTED .

esg:AntiCompetitiveLegalLosses a esg:Metric ;
    rdfs:label "Anti-Competitive Legal Losses" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Total amount of monetary losses as a result of legal proceedings associated with anti-competitive behaviour regulations" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Presentation currency" ;
    esg:obtainedFrom esg:BRIBERYANDCORRUPTIONPAIINSUFFICIENTACTIONS .

esg:CriticalMaterialsRiskManagement a esg:Metric ;
    rdfs:label "Critical Materials Risk Management" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Description of the management of risks associated with the use of critical materials" ;
    esg:hasMetricType "Discussion" ;
    esg:hasUnit "n/a" ;
    esg:obtainedFrom esg:ENVSUPPLYCHAINMGT .

esg:DataSecurityRiskApproach a esg:Metric ;
    rdfs:label "Data Security Risk Approach" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Description of approach to identifying and addressing data security risks" ;
    esg:hasMetricType "Discussion" ;
    esg:hasUnit "n/a" ;
    esg:obtainedFrom esg:POLICYDATAPRIVACY .

esg:GrossGlobalScope1Emissions a esg:Metric ;
    rdfs:label "GrossGlobalScope1Emissions" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Gross global Scope 1 greenhouse gas (GHG) emissions" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Metric tonnes (t) CO₂-e" ;
    esg:obtainedFrom esg:CO2DIRECTSCOPE1 .

esg:PerfluorinatedCompoundsEmissions a esg:Metric ;
    rdfs:label "PerfluorinatedCompoundsEmissions" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Amount of total emissions from perfluorinated compounds" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Metric tonnes (t) CO₂-e" ;
    esg:obtainedFrom esg:ANALYTICESTIMATEDCO2TOTAL .

esg:Scope1EmissionsStrategy a esg:Metric ;
    rdfs:label "Scope1EmissionsStrategy" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Discussion of long-term and short-term strategy or plan to manage Scope 1 emissions" ;
    esg:hasMetricType "Discussion" ;
    esg:hasUnit "n/a" ;
    esg:obtainedFrom esg:TARGETS_EMISSIONS .

esg:TotalEnergyConsumed a esg:Metric ;
    rdfs:label "Total Energy Consumed" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Total energy consumed" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Gigajoules (GJ)" ;
    esg:obtainedFrom esg:ENERGYUSETOTAL .

esg:TotalWaterConsumed a esg:Metric ;
    rdfs:label "Total Water Consumed" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Total water consumed" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Cubic meters (m³)" ;
    esg:obtainedFrom esg:WATERCONSUMPTIONTOTAL .

esg:TotalWaterWithdrawn a esg:Metric ;
    rdfs:label "Total Water Withdrawn" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Total water withdrawn" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Cubic meters (m³)" ;
    esg:obtainedFrom esg:WATERWITHDRAWALTOTAL .

esg:HazardousWasteAmount a esg:Metric ;
    rdfs:label "Hazardous Waste Amount" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Amount of hazardous waste generated" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Metric tonnes (t)" ;
    esg:obtainedFrom esg:HAZARDOUSWASTE .

# =============================================================================
# CALCULATED METRICS (isCalculatedBy Model)
# =============================================================================

esg:GHGEmissionIntensity a esg:Metric ;
    rdfs:label "GHGEmissionIntensity" ;
    esg:hasType "Manual" ;
    esg:hasCalculationMethod "calculation_model" ;
    esg:hasDescription "GHG Intensity (tons CO2e per million USD) calculated from Scope 1 and Scope 2 emissions divided by revenue" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "tons CO2e per million USD" ;
    esg:isCalculatedBy esg:GHGEmissionIntensityModel .

esg:PercentageGridElectricity a esg:Metric ;
    rdfs:label "Percentage Grid Electricity" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "calculation_model" ;
    esg:hasDescription "Percentage of total energy consumed that is grid electricity" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Percentage (%)" ;
    esg:isCalculatedBy esg:GridElectricityRateModel .

esg:PercentageRenewableEnergy a esg:Metric ;
    rdfs:label "Percentage Renewable Energy" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "calculation_model" ;
    esg:hasDescription "Percentage of total energy consumed that is renewable energy" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Percentage (%)" ;
    esg:isCalculatedBy esg:RenewableEnergyRateModel .

esg:PercentageHazardousWasteRecycled a esg:Metric ;
    rdfs:label "Percentage Hazardous Waste Recycled" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "calculation_model" ;
    esg:hasDescription "Percentage of hazardous waste that was recycled" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Percentage (%)" ;
    esg:isCalculatedBy esg:HazardousWasteRecyclingRateModel .

esg:PercentageWaterConsumedHighStress a esg:Metric ;
    rdfs:label "Percentage Water Consumed High Stress" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "calculation_model" ;
    esg:hasDescription "Percentage of water consumed in regions with high baseline water stress" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Percentage (%)" ;
    esg:isCalculatedBy esg:HighStressWaterConsumptionRateModel .

esg:PercentageWaterWithdrawnHighStress a esg:Metric ;
    rdfs:label "Percentage Water Withdrawn High Stress" ;
    esg:hasType "SASBRequirement" ;
    esg:hasCalculationMethod "calculation_model" ;
    esg:hasDescription "Percentage of water withdrawn in regions with high baseline water stress" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Percentage (%)" ;
    esg:isCalculatedBy esg:HighStressWaterWithdrawalRateModel .

# =============================================================================
# MODELS
# =============================================================================

esg:GHGEmissionIntensityModel a esg:Model ;
    rdfs:label "GHGEmissionIntensityModel" ;
    esg:hasDescription "GHG Intensity calculation model: (Scope1 + Scope2 emissions) / Revenue" ;
    esg:hasFormula "(scope1_emissions + scope2_emissions) / revenue" ;
    esg:hasMathematicalExpression "GHG_Intensity = (Scope1_Emissions + Scope2_Emissions) / Revenue_in_Million_USD" ;
    esg:hasCalculationType "intensity_ratio" ;
    esg:requiresInputFrom esg:GrossGlobalScope1Emissions,
        esg:Scope2Emission,
        esg:Revenue ;
    esg:executesWith esg:GHGEmissionIntensityImplementation .

esg:GridElectricityRateModel a esg:Model ;
    rdfs:label "Grid Electricity Rate Model" ;
    esg:hasDescription "Percentage of energy consumed from grid electricity" ;
    esg:hasFormula "(grid_electricity / total_energy) * 100" ;
    esg:hasMathematicalExpression "Grid_Electricity_Percentage = (Grid_Electricity_Consumption / Total_Energy_Consumption) × 100%" ;
    esg:hasCalculationType "percentage_ratio" ;
    esg:requiresInputFrom esg:GridElectricity,
        esg:TotalEnergyConsumed ;
    esg:executesWith esg:GridElectricityRateImplementation .

esg:RenewableEnergyRateModel a esg:Model ;
    rdfs:label "Renewable Energy Rate Model" ;
    esg:hasDescription "Percentage of energy consumed that was renewable energy" ;
    esg:hasFormula "(renewable_energy / total_energy) × 100" ;
    esg:hasMathematicalExpression "Renewable_Energy_Percentage = (Renewable_Energy_Consumption / Total_Energy_Consumption) × 100%" ;
    esg:hasCalculationType "percentage_ratio" ;
    esg:requiresInputFrom esg:RenewableEnergy,
        esg:TotalEnergyConsumed ;
    esg:executesWith esg:RenewableEnergyRateImplementation .

esg:HazardousWasteRecyclingRateModel a esg:Model ;
    rdfs:label "Hazardous Waste Recycling Rate Model" ;
    esg:hasDescription "Percentage of hazardous waste recycled" ;
    esg:hasFormula "(recycled_hazardous_waste / total_hazardous_waste) * 100" ;
    esg:hasMathematicalExpression "Recycling_Percentage = (Recycled_Hazardous_Waste / Total_Hazardous_Waste) × 100%" ;
    esg:hasCalculationType "percentage_ratio" ;
    esg:requiresInputFrom esg:RecycledHazardousWaste,
        esg:HazardousWasteAmount ;
    esg:executesWith esg:HazardousWasteRecyclingRateImplementation .

esg:HighStressWaterConsumptionRateModel a esg:Model ;
    rdfs:label "High Stress Water Consumption Rate Model" ;
    esg:hasDescription "Percentage of water consumed in high stress regions" ;
    esg:hasFormula "(high_stress_water_consumed / total_water_consumed) * 100" ;
    esg:hasMathematicalExpression "High_Stress_Consumption_Percentage = (High_Stress_Water_Consumed / Total_Water_Consumed) × 100%" ;
    esg:hasCalculationType "percentage_ratio" ;
    esg:requiresInputFrom esg:HighStressWaterConsumed,
        esg:TotalWaterConsumed ;
    esg:executesWith esg:HighStressWaterConsumptionRateImplementation .

esg:HighStressWaterWithdrawalRateModel a esg:Model ;
    rdfs:label "High Stress Water Withdrawal Rate Model" ;
    esg:hasDescription "Percentage of water withdrawn in high stress regions" ;
    esg:hasFormula "(high_stress_water_withdrawn / total_water_withdrawn) * 100" ;
    esg:hasMathematicalExpression "High_Stress_Withdrawal_Percentage = (High_Stress_Water_Withdrawn / Total_Water_Withdrawn) × 100%" ;
    esg:hasCalculationType "percentage_ratio" ;
    esg:requiresInputFrom esg:HighStressWaterWithdrawn,
        esg:TotalWaterWithdrawn ;
    esg:executesWith esg:HighStressWaterWithdrawalRateImplementation .

esg:FinancedEmissionsCoveragePercentageModel a esg:Model ;
    rdfs:label "Financed Emissions Coverage Percentage Model" ;
    esg:hasDescription "Percentage of gross exposure covered in financed emissions calculations" ;
    esg:hasFormula "(covered_gross_exposure / total_gross_exposure) * 100" ;
    esg:hasMathematicalExpression "Coverage_Percentage = (Gross_Exposure_Covered_In_Calculation / Total_Gross_Exposure) × 100%" ;
    esg:hasCalculationType "percentage_ratio" ;
    esg:requiresInputFrom esg:GrossExposureCovered,
        esg:TotalGrossExposure ;
    esg:executesWith esg:FinancedEmissionsCoveragePercentageImplementation .

# =============================================================================
# ADDITIONAL ESG METRICS (used as inputs for calculated metrics)
# Note: These are ESG metrics that serve as inputs to calculation models.
# They follow the same pattern: hasDataDomain + hasCalculationMethod + obtainedFrom
# =============================================================================

esg:Scope2Emission a esg:Metric ;
    rdfs:label "Scope 2 Emission" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Indirect greenhouse gas emissions from purchased electricity, steam, heating and cooling" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "tons CO2e" ;
    esg:obtainedFrom esg:CO2INDIRECTSCOPE2 .

esg:GridElectricity a esg:Metric ;
    rdfs:label "Grid Electricity" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Energy consumed from grid electricity" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Gigajoules (GJ)" ;
    esg:obtainedFrom esg:ELECTRICITYPURCHASED .

esg:RenewableEnergy a esg:Metric ;
    rdfs:label "Renewable Energy" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Energy consumed from renewable sources" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Gigajoules (GJ)" ;
    esg:obtainedFrom esg:RENEWENERGYPURCHASED .

esg:RecycledHazardousWaste a esg:Metric ;
    rdfs:label "Recycled Hazardous Waste" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Amount of hazardous waste that was recycled" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Metric tonnes (t)" ;
    esg:obtainedFrom esg:RECYCLEDHAZARDOUSWASTE .

esg:HighStressWaterConsumed a esg:Metric ;
    rdfs:label "High Stress Water Consumed" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Water consumed in regions with high baseline water stress" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Cubic meters (m³)" ;
    esg:obtainedFrom esg:WATERCONSUMPTIONTOTAL .

esg:HighStressWaterWithdrawn a esg:Metric ;
    rdfs:label "High Stress Water Withdrawn" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Water withdrawn in regions with high baseline water stress" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "Cubic meters (m³)" ;
    esg:obtainedFrom esg:WATERWITHDRAWALTOTAL .

esg:GrossExposureCovered a esg:Metric ;
    rdfs:label "Gross Exposure Covered" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Gross exposure to carbon-related assets covered in financed emissions calculation" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "million USD" ;
    esg:obtainedFrom esg:GROSS_EXPOSURE_COVERED .

esg:TotalGrossExposure a esg:Metric ;
    rdfs:label "Total Gross Exposure" ;
    esg:hasDataDomain "ESG" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Total gross exposure to all financed assets" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "million USD" ;
    esg:obtainedFrom esg:TOTAL_GROSS_EXPOSURE .

# =============================================================================
# FINANCIAL METRICS (non-ESG data used for intensity calculations)
# Note: Financial data required for ESG intensity metric calculations.
# hasDataDomain = "Financial" distinguishes from ESG metrics.
# =============================================================================

esg:Revenue a esg:Metric ;
    rdfs:label "Revenue" ;
    esg:hasDataDomain "Financial" ;
    esg:hasCalculationMethod "direct_measurement" ;
    esg:hasDescription "Total company revenue for the reporting period in millions of USD" ;
    esg:hasMetricType "Quantitative" ;
    esg:hasUnit "million USD" ;
    esg:obtainedFrom esg:revt .

# =============================================================================
# IMPLEMENTATIONS
# =============================================================================

esg:GHGEmissionIntensityImplementation a esg:Implementation ;
    rdfs:label "GHG Emission Intensity Implementation" ;
    esg:hasLanguage "Python" ;
    esg:hasFilePath "models/ghg_emission_intensity_model.py" ;
    esg:hasFunction "calculate_ghg_emission_intensity" ;
    esg:hasDescription "Python implementation for calculating GHG emission intensity" ;
    esg:hasInputParameters "scope1_emissions: float, scope2_emissions: float, revenue: float" ;
    esg:hasReturnType "float" ;
    esg:hasValidation "Revenue must be greater than 0 to avoid division by zero" .

esg:GridElectricityRateImplementation a esg:Implementation ;
    rdfs:label "Grid Electricity Rate Implementation" ;
    esg:hasLanguage "Python" ;
    esg:hasFilePath "models/energy_rate_models.py" ;
    esg:hasFunction "calculate_grid_electricity_rate" ;
    esg:hasDescription "Python implementation for calculating grid electricity percentage" ;
    esg:hasInputParameters "grid_electricity: float, total_energy: float" ;
    esg:hasReturnType "float" ;
    esg:hasValidation "Total energy must be greater than 0 to avoid division by zero" .

esg:RenewableEnergyRateImplementation a esg:Implementation ;
    rdfs:label "Renewable Energy Rate Implementation" ;
    esg:hasLanguage "Python" ;
    esg:hasFilePath "models/energy_rate_models.py" ;
    esg:hasFunction "calculate_renewable_energy_rate" ;
    esg:hasDescription "Python implementation for calculating renewable energy percentage" ;
    esg:hasInputParameters "renewable_energy: float, total_energy: float" ;
    esg:hasReturnType "float" ;
    esg:hasValidation "Total energy must be greater than 0 to avoid division by zero" .

esg:HazardousWasteRecyclingRateImplementation a esg:Implementation ;
    rdfs:label "Hazardous Waste Recycling Rate Implementation" ;
    esg:hasLanguage "Python" ;
    esg:hasFilePath "models/waste_rate_models.py" ;
    esg:hasFunction "calculate_hazardous_waste_recycling_rate" ;
    esg:hasDescription "Python implementation for calculating hazardous waste recycling percentage" ;
    esg:hasInputParameters "recycled_hazardous_waste: float, total_hazardous_waste: float" ;
    esg:hasReturnType "float" ;
    esg:hasValidation "Total hazardous waste must be greater than 0 to avoid division by zero" .

esg:HighStressWaterConsumptionRateImplementation a esg:Implementation ;
    rdfs:label "High Stress Water Consumption Rate Implementation" ;
    esg:hasLanguage "Python" ;
    esg:hasFilePath "models/water_rate_models.py" ;
    esg:hasFunction "calculate_high_stress_water_consumption_rate" ;
    esg:hasDescription "Python implementation for calculating high stress water consumption percentage" ;
    esg:hasInputParameters "high_stress_water_consumed: float, total_water_consumed: float" ;
    esg:hasReturnType "float" ;
    esg:hasValidation "Total water consumed must be greater than 0 to avoid division by zero" .

esg:HighStressWaterWithdrawalRateImplementation a esg:Implementation ;
    rdfs:label "High Stress Water Withdrawal Rate Implementation" ;
    esg:hasLanguage "Python" ;
    esg:hasFilePath "models/water_rate_models.py" ;
    esg:hasFunction "calculate_high_stress_water_withdrawal_rate" ;
    esg:hasDescription "Python implementation for calculating high stress water withdrawal percentage" ;
    esg:hasInputParameters "high_stress_water_withdrawn: float, total_water_withdrawn: float" ;
    esg:hasReturnType "float" ;
    esg:hasValidation "Total water withdrawn must be greater than 0 to avoid division by zero" .

# =============================================================================
# DATASET VARIABLES
# =============================================================================

esg:CO2DIRECTSCOPE1 a esg:DatasetVariable ;
    rdfs:label "CO2DIRECTSCOPE1" ;
    esg:alignmentReason "Direct mapping for Scope 1 GHG emissions" ;
    esg:hasConfidenceScore 100 ;
    esg:isUnitCompatible "Yes - both measure CO2e in metric tonnes" ;
    esg:SourcesFrom esg:SemiconductorsEurofidaiEnvironmentDataset,
        esg:CommercialBanksEurofidaiEnvironmentDataset .

esg:CO2INDIRECTSCOPE2 a esg:DatasetVariable ;
    rdfs:label "CO2INDIRECTSCOPE2" ;
    esg:alignmentReason "Direct mapping for Scope 2 GHG emissions" ;
    esg:hasConfidenceScore 100 ;
    esg:isUnitCompatible "Yes - both measure CO2e in metric tonnes" ;
    esg:SourcesFrom esg:SemiconductorsEurofidaiEnvironmentDataset,
        esg:CommercialBanksEurofidaiEnvironmentDataset .

esg:revt a esg:DatasetVariable ;
    rdfs:label "revt" ;
    esg:alignmentReason "Total revenue variable for financial calculations and intensity metrics" ;
    esg:hasConfidenceScore 100 ;
    esg:isUnitCompatible "Yes - both measure revenue in USD" ;
